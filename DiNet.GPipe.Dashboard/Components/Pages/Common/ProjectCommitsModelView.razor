@using DiNet.GPipe.Application.Handlers.Commits.Get
@using DiNet.GPipe.Dashboard.Api
@inject WebApi Api

<div class="card shadow-sm">
    <div class="card-header bg-white">
        <h4 class="mb-0">Commits</h4>
    </div>

    <nav class="nav flex-column p-2" style="max-height: 300px; overflow-y: auto; flex-wrap: nowrap;">
        @if (_commits != null)
        {
            @foreach (var commit in _commits)
            {
                <div>
                    <span class="fw-semibold text-dark"> @commit.Name </span>
                </div>
                <div>
                    <span class="fw-semibold text-dark"> @commit.Hash </span>
                </div>
                <div class="border-bottom">
                    <label class="text-muted small d-block">Version</label>
                    <span class="badge bg-secondary"> @($"{commit.BuildVersion.release}.{commit.BuildVersion.beta}.{commit.BuildVersion.alpha}")
                    </span>
                </div>
            }
        }
    </nav>
</div>

@code {
    [Parameter]
    public int ProjectId { get; set; }

    private CommitResponse[]? _commits;

    protected override async Task OnInitializedAsync()
    {
        _commits = await Api.GetProjectCommits(ProjectId, false, default);

        //_commits = [new() { Name = "c1", BuildVersion = new(1, 2, 3), Hash = "asd123" }, new(){ Name = "c3", BuildVersion = new(1, 2, 3), Hash = "asd123" }];
    }
}
