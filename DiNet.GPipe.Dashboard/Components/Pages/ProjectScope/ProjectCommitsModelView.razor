@using BlazorBootstrap
@using DiNet.GPipe.Application.Handlers.Commits.Get
@using DiNet.GPipe.Dashboard.Api
@inject IProjectApi Api
@inject IBuildingApi BuildingApi
@inject ToastService ToastService

<div class="card shadow-sm">
    <div class="card-header bg-white">
        <h4 class="mb-0">Commits</h4>
    </div>

    <nav class="nav flex-column p-2" style="max-height: 300px; overflow-y: auto; flex-wrap: nowrap;">
        @if (_commits != null)
        {
            @foreach (var commit in _commits)
            {
                var commitRef = commit;
                <div class="d-flex align-items-center">
                    <div>
                        <span class="fw-semibold text-dark"> @commit.Name </span>
                        <span class="fw-semibold small text-dark"> @commit.Hash </span>

                        <label class="text-muted small d-block">Version</label>
                        <span class="badge bg-secondary">
                            @($"{commit.BuildVersion.release}.{commit.BuildVersion.beta}.{commit.BuildVersion.alpha}")
                        </span>
                    </div>

                    <button type="button" class="btn btn-sm btn-outline-success" @onclick="() => EnqueueBuild(commitRef)">
                        <i class="bi bi-archive-fill"></i>
                    </button>
                </div>

                <div class="border-bottom" />
            }
        }
    </nav>
</div>

@code {
    [Parameter]
    public int ProjectId { get; set; }

    private CommitResponse[]? _commits;

    protected override async Task OnInitializedAsync()
    {
        _commits = await Api.GetProjectCommits(ProjectId, false);
    }

    private async Task EnqueueBuild(CommitResponse commit)
    {
        var result = await BuildingApi.EnqueueBuild(commit.ProjectId, commit.Hash);
        if (result.IsSuccessStatusCode)
        {
            ToastService.Notify(new(ToastType.Success, $"Enqueued with {result.StatusCode}"));
        }
        else
        {
            ToastService.Notify(new(ToastType.Danger, $"Error {result.StatusCode}"));
        }
    }
}
