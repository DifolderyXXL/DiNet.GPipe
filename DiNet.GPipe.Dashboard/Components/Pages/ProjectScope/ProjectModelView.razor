@using DiNet.GPipe.Application.Handlers.Projects.Get
@using DiNet.GPipe.Dashboard.Api
@using DiNet.GPipe.Dashboard.Components.Common
@using DiNet.GPipe.Dashboard.Components.Pages.ProjectScope.Branch
@using DiNet.GPipe.Dashboard.Models
@using DiNet.GPipe.Dashboard.Models.Forms
@using DiNet.GPipe.SharedKernel.Watchers

@if (Project != null)
{
    <div class="card shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <SelfEditableField TValue="string" @bind-Value=Project.Name OnSave="SaveProjectName">
                <InputTemplate Context="model">
                    <InputText @bind-Value=model.Value class="form-control" />
                </InputTemplate>
                <DisplayTemplate Context="value">
                    @value.ToString()
                </DisplayTemplate>
            </SelfEditableField>

            <h4 class="mb-0">@Project.Name</h4>

            <button type="button" class="btn btn-sm btn-outline-danger" @onclick=RemoveRequest>
                <i class="bi bi-trash"></i>
            </button>
        </div>
        <div class="card-body">
            <SelfEditableField TValue="string" @bind-Value=Project.GitUrl OnSave="SaveGitUrl">
                <InputTemplate Context="model">
                    <label class="text-muted small d-block">Git URL</label>

                    <InputText @bind-Value=model.Value class="form-control" />
                </InputTemplate>
                <DisplayTemplate Context="value">

                    <div class="mb-3">
                        <label class="text-muted small d-block">Git URL</label>

                        <a href="@value" target="_blank">@value</a>
                    </div>

                </DisplayTemplate>
            </SelfEditableField>

            
            <div class="mb-3">
                <label class="text-muted small d-block">Poll Interval</label>
                <span class="badge bg-secondary">@Project.PollInterval hh:mm:ss</span>
            </div>
            <div class="mb-3">
                <label class="text-muted small d-block mb-1">Branches</label>
                <div class="ps-3">

                    @foreach (var branch in Project.Branches)
                    {
                        var targetBranch = new BranchForm()
                        {
                            BranchName = branch.Name,
                            VersionType = branch.version
                        };
                        <BranchEditableView branch=targetBranch OnEdited=@((x) => BranchEdited(targetBranch.BranchName, x))
                                            OnRemove=BranchRemoveRequest />
                    }

                    @if (!_isAddingNewBranch)
                    {

                        <button type="button" class="btn btn-sm btn-outline-primary mt-2" @onclick=StartAddingNewBranch>
                            <i class="bi bi-plus-circle me-1"></i> Add Branch
                        </button>
                    }
                    else
                    {
                        <div class="d-flex align-items-center gap-2 mb-2 p-2 rounded-2 bg-light border shadow-sm">
                            <BranchEditView branch=_branchForm />

                            
                            <button type="button" class="btn btn-sm btn-outline-success" @onclick=CommitButton>
                                <i class="bi bi-check"></i>
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-danger" @onclick=CancelCreationBranch>
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    }

                </div>
            </div>

            @if (Project.IsActive)
            {
                <button type="button" class="btn btn-sm btn-outline-success" @onclick="() => ChangeActiveProject(false)">
                    <i class="bi bi-check"></i> Active
                </button>
            }
            else
            {
                <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => ChangeActiveProject(true)">
                    <i class="bi bi-x"></i> Inactive
                </button>
            }
        </div>
    </div>
}


@code {
    [Inject] protected IWebApi Api { get; set; }

    [Parameter]
    public EventCallback RemoveRequested { get; set; }

    [Parameter]
    public ProjectState Project { get; set; }

    private BranchForm? _branchForm;

    private ProjectState? _previousProject;

    protected override void OnParametersSet()
    {
        if (Project != _previousProject)
        {
            _isAddingNewBranch = false;
            _branchForm = null;
            _previousProject = Project;
        }
    }

    private async Task SaveProjectName(string name)
    {
        await Api.UpdateProjectName(Project.Id, name, default);
    }
    private async Task SaveGitUrl(string name)
    {
        await Api.UpdateProjectGitUrl(Project.Id, name, default);
    }

    public bool _isAddingNewBranch = false;
    public void StartAddingNewBranch()
    {
        _branchForm = new();
        _isAddingNewBranch = true;

        StateHasChanged();
    }
    public void CancelCreationBranch()
    {
        _branchForm = null;
        _isAddingNewBranch = false;

        StateHasChanged();
    }

    public async Task CommitButton()
    {
        if (Project == null || _branchForm == null)
            return;

        var branch = new BranchConfig(_branchForm.BranchName, _branchForm.VersionType);

        _branchForm = null;
        _isAddingNewBranch = false;

        await Api.AddBranch(Project.Id, branch, default);
        Project.Branches.Add(new(branch.BranchName, branch.VersionType));

        StateHasChanged();
    }

    public async Task BranchEdited(string targetName, BranchDto branch)
    {
        if (Project == null)
            return;

        var index = Project.Branches.FindIndex(x => x.Name == targetName);
        Project.Branches[index] = branch;

        await Api.UpdateBranch(Project.Id, targetName, new(branch.Name, branch.version), default);

        StateHasChanged();
    }

    public async Task BranchRemoveRequest(BranchDto branch)
    {
        if (Project == null)
            return;

        await Api.RemoveBranch(Project.Id, branch.Name, default);
        Project.Branches.RemoveAll(x => x.Name == branch.Name);

        StateHasChanged();
    }


    public async Task RemoveRequest()
    {
        await RemoveRequested.InvokeAsync();
    }

    public async Task ChangeActiveProject(bool active)
    {
        if (Project == null)
            return;

        Project.IsActive = active;
        await Api.WatcherChangeActive(Project.Id, active, default);

        StateHasChanged();
    }
}
